
#!/usr/bin/env bash

CIPHER="$HOME/Downloads/cipher"
PLAIN="$HOME/Downloads/plain"

# Create directories if they don't exist
mkdir -p "$CIPHER" "$PLAIN"

# Check if mountpoint is already mounted
if mountpoint -q "$PLAIN"; then
    # Unmount if already mounted
    fusermount3 -u "$PLAIN"
    notify-send "Vault" "Unmounted successfully"
    exit 0
fi

# Prompt for password
PASSWORD=$(zenity --password --title="Mount Vault")
if [[ -z "$PASSWORD" ]]; then
    notify-send "Vault" "Mount cancelled"
    exit 1
fi

# Use a temporary file for safe password passing
TMPFILE=$(mktemp)
chmod 600 "$TMPFILE"
printf "%s" "$PASSWORD" > "$TMPFILE"

# Mount the encrypted folder
gocryptfs -extpass="cat $TMPFILE" "$CIPHER" "$PLAIN"

# Delete the temporary password file
shred -u "$TMPFILE"

notify-send "Vault" "Mounted successfully"

