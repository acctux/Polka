#!/bin/bash
# Nemo script to copy selected file or folder full paths

# Convert all selections to full paths
full_paths=""
for f in "$@"; do
    full_paths+=$(realpath "$f")$'\n'
done

# Copy to clipboard
printf "%s" "$full_paths" | wl-copy  # use xclip for X11: xclip -selection clipboard

# Optional: show notification
notify-send "Nemo" "Copied full path(s) to clipboard"

