export TERMINAL=kitty
export EDITOR=nvim
export BROWSER=brave

export GPG_TTY=$(tty)

export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/gcr/ssh"

export XCURSOR_THEME=capitaine-cursors-light
