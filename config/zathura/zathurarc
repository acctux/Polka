# Enable recolor (dark mode)
set recolor true

# Optional: only invert text & background, leave images normal
set recolor-lightcolor "#101013"   # background color
set recolor-darkcolor "#F4F5F6"    # text color

# Optional: smooth scrolling / keybindings
set smoothscroll true
set scroll-step 20

# Optional: show page number in statusbar
set statusbar true
